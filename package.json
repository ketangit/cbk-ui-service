{
  "name": "cbk-ui-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.9.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps"
  },
  "dependencies": {
    "firebase": "12.14.0",
    "next": "15.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "three": "0.170.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@playwright/test": "1.51.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.2.0",
    "@types/node": "22.13.10",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "@types/three": "0.170.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "9.22.0",
    "eslint-config-next": "15.3.0",
    "eslint-config-prettier": "10.1.1",
    "jsdom": "26.0.0",
    "prettier": "3.5.3",
    "typescript": "5.8.2",
    "vitest": "3.0.9"
  }
}
